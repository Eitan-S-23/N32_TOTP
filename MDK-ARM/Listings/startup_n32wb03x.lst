   43 00000800         __initial_sp
   44 00000800         
   45 00000800         ; <h> Heap Configuration
   46 00000800         ;   <o>  Heap Size (in Bytes) <0x0-0xFFFFFFFF:8>
   47 00000800         ; </h>
   48 00000800         
   49 00000800         ; libc heap. FreeRTOS itself doesn't need this (static a
                       llocation only,
   50 00000800         ; see user/FreeRTOSConfig.h). However the pre-built Nati
                       onstech BLE
   51 00000800         ; library pulls in malloc internally — zeroing this ca
                       used malloc() to
   52 00000800         ; return NULL during ns_ble_task_init and HardFaulted on
                        first use, so
   53 00000800         ; we keep the original 512-byte heap.
   54 00000800 00000200 
                       Heap_Size
